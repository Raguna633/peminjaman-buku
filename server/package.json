{
  "type": "module",
  "name": "server",
  "version": "1.0.0",
  "main": "app.js",
  "scripts": {
    "test": "vitest",
    "coverage": "vitest --coverage",
    "dev": "cross-env NODE_ENV=development nodemon app",
    "prod": "cross-env NODE_ENV=development pm2 start app.js --name peminjaman-buku --watch && npx pm2 monit",
    "monitor": "npx pm2 monit",
    "stop": "npx pm2 stop peminjaman-buku",
    "restart": "npx pm2 restart peminjaman-buku && npx pm2 monit",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:undo": "npx sequelize-cli db:seed:undo:all",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.16.2",
    "node-cron": "^3.0.3",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^11.7.0",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.11",
    "sequelize-cli": "^6.6.5",
    "vitest": "^4.0.18"
  }
}
